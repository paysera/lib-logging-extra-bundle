<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="paysera_logging_extra.formatter.line"
                 class="Paysera\LoggingExtraBundle\Service\Formatter\LineFormatter"/>

        <service id="paysera_logging_extra.formatter.gelf_message"
                 class="Paysera\LoggingExtraBundle\Service\Formatter\GelfMessageFormatter">
            <argument>%paysera_logging_extra.application_name%</argument>
        </service>

        <service id="paysera_logging_extra.service.exception_message_parser"
                 class="Paysera\LoggingExtraBundle\Service\ExceptionMessageParser"/>

        <service id="paysera_logging_extra.formatter.stdout_record_encoder"
                 class="Paysera\LoggingExtraBundle\Service\Formatter\StdoutRecordEncoder">
            <argument>%paysera_logging_extra.application_name%</argument>
            <argument type="service" id="paysera_logging_extra.service.exception_message_parser"/>
        </service>

        <service id="paysera_logging_extra.formatter.stdout_json"
                 class="Paysera\LoggingExtraBundle\Service\Formatter\StdoutJsonFormatter">
            <argument type="service" id="paysera_logging_extra.formatter.stdout_record_encoder"/>
        </service>
    </services>
</container>
